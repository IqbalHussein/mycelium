{
  "manifest_version": 3,
  "name": "Mycelium",
  "version": "1.0.0",
  "description": "Visualize async network traffic as Sequence Diagrams in Chrome DevTools.",
  "permissions": [
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "devtools_page": "devtools.html"
}